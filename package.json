{
  "name": "botrucho",
  "version": "1.7.1",
  "description": "",
  "main": "src/sharder.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "copy-env": "npx cpx \".env.*\" dist/",
    "copy-assets": "npx cpx \"assets/**/*\" dist/assets && npx cpx \"languages/**/*\" dist/languages",
    "build": "swc src -d dist -s -D && npm run copy-assets && npm run copy-env",
    "start": "npm run build && dotenvx run -f .env.development -- node dist/src/sharder.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/builders": "^1.13.1",
    "@discordjs/rest": "^2.6.0",
    "@dotenvx/dotenvx-pro": "^0.26.1",
    "canvas": "^3.2.1",
    "discord-api-types": "^0.38.41",
    "discord-player": "^7.2.0",
    "discord-player-googlevideo": "^0.2.2",
    "discord-player-youtubei": "^1.5.0",
    "discord-voip": "^7.2.0",
    "discord.js": "^14.25.1",
    "express": "^5.2.1",
    "gif-encoder-2": "^1.0.5",
    "jimp": "^1.6.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "mongoose": "^9.2.4",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/cli": "^0.8.0",
    "@swc/core": "1.13.5",
    "@types/express": "^5.0.6",
    "@types/node-cron": "^3.0.11",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=22.x"
  }
}
